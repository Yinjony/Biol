@import "../../pages/common/bio.wxss";

.question-editor-card {
  position: relative;
}

.editor-title {
  color: #1f2a24;
  font-size: 28rpx;
  font-weight: 700;
}

.editor-question-input,
.editor-option-input {
  box-sizing: border-box;
}

.editor-question-input {
  width: 100%;
  min-height: 78rpx;
  max-height: 300rpx; /* 增加最大高度限制 */
  overflow-y: auto;   /* 超出部分滚动 */
  padding: 20rpx 22rpx;
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
  line-height: 1.55;
}

.editor-answer-field {
  position: relative;
  z-index: 1;
  width: 100%;
  box-sizing: border-box;
}

.editor-answer-field.menu-open {
  z-index: 30;
}

.editor-answer-button {
  position: relative;
  width: 100% !important;       /* 强制 100% */
  margin: 0 !important;         /* 【核心】清除 button 默认的左右 margin，解决居中和间距问题 */
  padding: 0 64rpx 0 22rpx !important; /* 清除默认 padding，保留你需要的 */
  box-sizing: border-box;
  min-height: 78rpx;
  
  border: 1rpx solid #cfeadb;
  border-radius: 16rpx;
  background: #edf8f1;
  color: #14663f;
  font-size: 28rpx;
  line-height: 78rpx;
  text-align: left;
}

.editor-answer-button::before {
  position: absolute;
  top: 50%;
  right: 24rpx;
  width: 0;
  height: 0;
  margin-top: -4rpx;
  border-top: 10rpx solid #68746d;
  border-right: 8rpx solid transparent;
  border-left: 8rpx solid transparent;
  content: '';
}

/* 彻底清除 button 默认的 ::after 边框 */
.editor-answer-button::after,
.editor-answer-option::after {
  display: none !important; /* 用 display: none 比 border: 0 更彻底 */
}

.editor-answer-menu {
  position: absolute;
  top: calc(100% + 8rpx);
  right: 0;
  left: 0;
  width: 100%;
  box-sizing: border-box;
  z-index: 31;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 10rpx;
  border: 1rpx solid #dce5df;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(31, 42, 36, 0.16);
}

.editor-answer-option {
  width: 100% !important;
  margin: 0 !important;         /* 【核心】清除选项 button 的默认 margin */
  padding: 0 18rpx !important;  /* 清除默认 padding */
  box-sizing: border-box;
  min-height: 64rpx;
  
  border: 1rpx solid #dce5df;
  border-radius: 12rpx;
  background: #ffffff;
  color: #45534b;
  font-size: 26rpx;
  line-height: 64rpx;
  text-align: left;
}

.editor-answer-option.selected {
  border-color: #1f8a5b;
  background: #e8f5ee;
  color: #14663f;
}

/* 选项部分样式保持不变 */
.editor-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.editor-option {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.editor-option-label {
  flex: 0 0 44rpx;
  color: #45534b;
  font-size: 28rpx;
}

.editor-option-input {
  flex: 1;
  width: auto;
}

.editor-actions {
  align-items: stretch;
}

.editor-save-button {
  min-height: 62rpx;
  padding: 0 28rpx;
  font-size: 24rpx;
}
