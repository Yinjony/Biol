page {
  min-height: 100%;
  background: #f4f7f5;
  color: #1f2a24;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

view,
text,
input,
textarea,
picker,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.4;
}

button::after {
  border: 0;
}

input,
textarea {
  min-height: 0;
}
