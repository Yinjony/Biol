{
  "pages": [
    "pages/bank/index",
    "pages/quiz/index",
    "pages/create/index"
  ],
  "window": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "生物做题",
    "navigationBarBackgroundColor": "#10251d",
    "backgroundColor": "#f4f7f5"
  },
  "tabBar": {
    "color": "#68746d",
    "selectedColor": "#1f8a5b",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/bank/index",
        "iconPath": "image/record.png",
        "selectedIconPath": "image/record.png",
        "text": "题库管理"
      },
      {
        "pagePath": "pages/quiz/index",
        "iconPath": "image/play.png",
        "selectedIconPath": "image/play.png",
        "text": "随机练习"
      },
      {
        "pagePath": "pages/create/index",
        "iconPath": "image/plus.png",
        "selectedIconPath": "image/plus_dark.png",
        "text": "新增题目"
      }
    ]
  },
  "networkTimeout": {
    "request": 10000,
    "connectSocket": 10000,
    "uploadFile": 10000,
    "downloadFile": 10000
  },
  "cloud": true,
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "useExtendedLib": {
    "kbone": true,
    "weui": true
  }
}
