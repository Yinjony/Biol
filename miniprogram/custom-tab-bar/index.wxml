<view class="tab-bar">
  <view
    wx:for="{{tabs}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'selected' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image class="tab-icon" src="{{selected === index ? item.selectedIconUrl : item.iconUrl}}" mode="aspectFit" />
    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
