.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  background: #f4f7f5;
}

.hero-panel {
  padding: 28rpx;
  border-radius: 16rpx;
  background: #10251d;
  color: #f7fbf8;
}

.hero-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.hero-logo {
  flex: 0 0 auto;
  width: 92rpx;
  height: 92rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
}

.hero-copy {
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-meta {
  display: block;
  margin-top: 8rpx;
  color: rgba(247, 251, 248, 0.68);
  font-size: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.stat-item {
  min-height: 108rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.15;
}

.stat-label {
  color: rgba(247, 251, 248, 0.7);
  font-size: 22rpx;
}

.section {
  margin-top: 22rpx;
}

.card,
.empty-state {
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(31, 42, 36, 0.06);
}

.card {
  padding: 24rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.toolbar-title {
  display: block;
  color: #1f2a24;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.toolbar-meta {
  display: block;
  margin-top: 6rpx;
  color: #68746d;
  font-size: 24rpx;
}

.search-card {
  padding: 18rpx;
}

.field {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.field + .field,
.option-fields,
.form-actions,
.parse-panel {
  margin-top: 18rpx;
}

.field-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 208rpx;
  gap: 18rpx;
}

.field-label {
  color: #68746d;
  font-size: 24rpx;
}

.text-input,
.picker-input,
.textarea {
  width: 100%;
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
}

.text-input,
.picker-input {
  min-height: 78rpx;
  padding: 0 22rpx;
  line-height: 78rpx;
}

.textarea {
  min-height: 180rpx;
  padding: 20rpx 22rpx;
  line-height: 1.55;
}

.large-textarea {
  min-height: 420rpx;
}

.option-fields {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.primary-button,
.secondary-button,
.tiny-button,
.mode-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  padding: 0 26rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.primary-button {
  background: #1f8a5b;
  color: #ffffff;
}

.secondary-button,
.tiny-button,
.mode-button {
  border: 1rpx solid #dce5df;
  background: #ffffff;
  color: #1f2a24;
}

.button-hover,
.mode-button.active {
  opacity: 0.84;
}

.mode-button.active {
  border-color: #1f8a5b;
  background: #dff3e8;
  color: #14663f;
}

.form-actions,
.card-actions,
.inline-actions,
.mode-row {
  display: flex;
  gap: 14rpx;
}

.form-actions {
  justify-content: flex-end;
}

.inline-actions,
.mode-row {
  flex-wrap: wrap;
}

.inline-actions button,
.mode-row button {
  flex: 1 1 200rpx;
}

.question-list,
.quiz-board {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.question-card,
.quiz-card {
  padding: 24rpx;
}

.card-header,
.quiz-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.question-title {
  flex: 1;
  min-width: 0;
  color: #1f2a24;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-word;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  background: #e1eef7;
  color: #245679;
  font-size: 22rpx;
  line-height: 44rpx;
  white-space: nowrap;
}

.answer-tag {
  background: #dff3e8;
  color: #14663f;
}

.card-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
  color: #68746d;
  font-size: 26rpx;
  line-height: 1.55;
}

.option-line {
  white-space: pre-wrap;
  word-break: break-word;
}

.card-actions {
  justify-content: flex-end;
  margin-top: 20rpx;
}

.tiny-button {
  min-height: 62rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.danger-text {
  color: #bf4b32;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 280rpx;
  padding: 36rpx;
  color: #68746d;
  font-size: 28rpx;
  text-align: center;
}

.pager-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  gap: 28rpx;
  padding: 8rpx 0;
}

.pager-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-width: 208rpx;
  min-height: 76rpx;
  margin: 0;
  padding: 0 30rpx;
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
  font-weight: 400;
  transition: all 0.2s;
}

.pager-text {
  flex: 0 0 auto;
  margin: 0;
  color: #68746d;
  font-size: 26rpx;
  text-align: center;
  white-space: nowrap;
}

.pager-chevron {
  flex: 0 0 auto;
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
}

.pager-chevron-left {
  transform: rotate(-135deg);
}

.pager-chevron-right {
  transform: rotate(45deg);
}

.pager-prev {
  justify-self: start;
}

.pager-next {
  justify-self: end;
}

.pager-button[disabled],
.answer-option[disabled] {
  opacity: 1;
}

.pager-button[disabled] {
  border-color: #e4ebe6;
  background: #f2f5f3;
  color: #aab4ae;
}

.backtop-button {
  position: fixed;
  right: 30rpx;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  z-index: 20;

  display: flex;
  align-items: center;
  justify-content: center;

  box-sizing: border-box;
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0; /* view 没有默认 padding，这里写 0 即可 */

  border: 1rpx solid rgba(31, 138, 91, 0.28);
  border-radius: 999rpx;
  background: #ffffff;
  color: #14663f;

  box-shadow: 0 12rpx 28rpx rgba(31, 42, 36, 0.16);
  overflow: hidden;
}

/* 向上的三角形 */
.backtop-arrow {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 18rpx solid #14663f;
}

/* 点击态 */
.button-hover {
  opacity: 0.85;
  transform: scale(0.96);
}


.quiz-control-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.quiz-control-row .primary-button,
.quiz-control-row .secondary-button {
  flex: 1 1 180rpx;
}

.submit-section {
  margin-bottom: 18rpx;
}

.submit-button {
  width: 100%;
}

.count-picker {
  flex: 1 1 220rpx;
}

.quiz-count-label {
  display: flex;
  align-items: center;
  color: #68746d;
  font-size: 28rpx;
  white-space: nowrap;
}

.dropdown-field {
  position: relative;
  z-index: 2;
}

.dropdown-trigger {
  position: relative;
  width: 100%;
  min-height: 78rpx;
  margin: 0;
  padding: 0 64rpx 0 22rpx;
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
  line-height: 78rpx;
  text-align: left;
}

.dropdown-trigger::before {
  position: absolute;
  top: 50%;
  right: 24rpx;
  width: 0;
  height: 0;
  margin-top: -4rpx;
  border-top: 10rpx solid #68746d;
  border-right: 8rpx solid transparent;
  border-left: 8rpx solid transparent;
  content: '';
}

.dropdown-trigger::after,
.dropdown-option::after {
  border: 0;
}

.quiz-count-button {
  width: auto;
}

.quiz-count-field {
  flex: 1 1 120rpx;
}

.dropdown-menu {
  position: absolute;
  top: calc(100% + 8rpx);
  right: 0;
  left: 0;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 10rpx;
  border: 1rpx solid #dce5df;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(31, 42, 36, 0.16);
}

.dropdown-option {
  width: 100%;
  min-height: 68rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #dce5df;
  border-radius: 12rpx;
  background: #ffffff;
  color: #45534b;
  font-size: 26rpx;
  line-height: 68rpx;
  text-align: left;
}

.dropdown-option.selected {
  border-color: #1f8a5b;
  background: #e8f5ee;
  color: #14663f;
}

.manual-select-row {
  position: relative;
  z-index: 1;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.manual-select-row.menu-open {
  z-index: 100;
}

.manual-select-row > .field + .field {
  margin-top: 0;
}

.question-content-field {
  position: relative;
  z-index: 1;
}

.import-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.import-button,
.import-save-button {
  width: 100%;
}

.import-hint,
.import-status {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
}

.import-hint {
  color: #68746d;
}

.import-status {
  color: #14663f;
}

.import-question-list {
  margin-top: 22rpx;
}

.import-save-section {
  margin-bottom: 18rpx;
}

.quiz-title-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  min-width: 0;
}

.quiz-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  background: #eef5ef;
  color: #14663f;
  font-size: 26rpx;
  font-weight: 800;
}

.answer-buttons {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.answer-option {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-height: 82rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
  line-height: 1.45;
  text-align: left;
  white-space: normal;
  word-break: break-word;
}

.answer-hover {
  border-color: #1f8a5b;
  background: #dff3e8;
}

.answer-option.correct {
  border-color: #167347;
  background: #dff6ea;
  color: #167347;
}

.answer-option.wrong {
  border-color: #bf4b32;
  background: #fde8e1;
  color: #bf4b32;
}

.feedback {
  margin-top: 18rpx;
  color: #68746d;
  font-size: 26rpx;
}

.feedback.correct {
  color: #167347;
}

.feedback.wrong {
  color: #bf4b32;
}

.parse-title {
  display: block;
  color: #1f2a24;
  font-size: 32rpx;
  font-weight: 800;
}

.parse-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.parse-label {
  color: #68746d;
  font-size: 24rpx;
}

.parse-value {
  color: #1f2a24;
  font-size: 28rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

@media (min-width: 720px) {
  .page-shell {
    max-width: 720px;
    margin: 0 auto;
  }

  .answer-buttons {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
