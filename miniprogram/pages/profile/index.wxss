@import "../common/bio.wxss";

.profile-card {
  padding: 28rpx 24rpx;
}

.profile-heading-title {
  display: block;
  color: #1f2a24;
  font-size: 34rpx;
  font-weight: 800;
}

.profile-status {
  display: block;
  margin-top: 8rpx;
  color: #68746d;
  font-size: 24rpx;
  line-height: 1.5;
}

.profile-avatar-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 30rpx;
}

.profile-avatar-button {
  width: 132rpx;
  height: 132rpx;
  margin: 0;
  padding: 0;
  overflow: hidden;
  border: 0;
  border-radius: 50%;
  background: transparent;
}

.profile-avatar-button::after {
  border: 0;
}

.profile-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}

.profile-avatar-placeholder {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  background: #dff3e8;
  border-radius: 50%;
  overflow: hidden;
}


/* 确保整个头像块是垂直居中排列的 */
.profile-avatar-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx; /* 增加顶部间距，让布局更舒展 */
}

.avatar-border-wrapper {
  position: relative;
  width: 170rpx; /* 比头像大10rpx */
  height: 170rpx;
  border-radius: 50%;
  /* 双层边框效果：外层浅灰 + 内层渐变 */
  background: 
    linear-gradient(135deg, #e6f7f0 0%, #d1eae0 100%),
    radial-gradient(circle, #3d8c78 0%, #a8e6cf 70%);
  box-shadow: 
    0 0 0 2rpx rgba(255, 255, 255, 0.6), /* 内层白边 */
    0 4rpx 12rpx rgba(61, 140, 120, 0.15); /* 外层阴影 */
  overflow: hidden;
  background: 
  radial-gradient(circle at 30% 30%, rgba(255,255,255,0.3) 0%, transparent 40%),
  linear-gradient(135deg, #e6f7f0 0%, #d1eae0 100%),
  radial-gradient(circle, #3d8c78 0%, #a8e6cf 70%);
  /* 添加平滑过渡效果 */
  transition: all 0.3s ease;
}

.avatar-wrapper {
  margin-bottom: 16rpx; /* 头像和提示文字之间的间距 */
}

/* 按钮样式调整 */
.profile-avatar-button {
  width: 160rpx;
  height: 160rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 0;
  background: transparent;
  z-index: 2;
}
.profile-avatar-button::after {
  border: 0;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

/* --- 核心修改：新的 Placeholder 样式 --- */
.profile-avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a8e6cf 0%, #3d8c78 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 1;
}

/* 头像中间的文字样式 */
.avatar-initial {
  color: #ffffff;
  font-size: 64rpx;
  font-weight: 500;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}
/* 提示文字样式微调 */
.profile-avatar-hint {
  color: #999999; /* 浅灰色 */
  font-size: 26rpx;
  margin-top: 0;
}

.profile-avatar-button:hover .avatar-border-wrapper {
  transform: scale(1.05);
  box-shadow: 
    0 0 0 2rpx rgba(255, 255, 255, 0.8),
    0 6rpx 16rpx rgba(61, 140, 120, 0.2);
}

.profile-avatar-copy {
  min-width: 0;
}

.profile-avatar-title,
.profile-avatar-hint {
  display: block;
}

.profile-avatar-title {
  color: #1f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.profile-avatar-hint {
  margin-top: 8rpx;
  color: #68746d;
  font-size: 24rpx;
  line-height: 1.5;
}

.profile-name-field {
  margin-top: 30rpx;
}

.profile-save-button {
  width: 100%;
  margin-top: 30rpx;
}

.profile-note {
  padding: 24rpx;
  border: 1rpx solid #d8e8df;
  border-radius: 16rpx;
  background: #edf7f1;
}

.profile-note-title,
.profile-note-text {
  display: block;
}

.profile-note-title {
  color: #14663f;
  font-size: 28rpx;
  font-weight: 800;
}

.profile-note-text {
  margin-top: 10rpx;
  color: #41604e;
  font-size: 24rpx;
  line-height: 1.65;
}
