<view class="page-shell">
  <view class="hero-panel">
    <view class="hero-brand">
      <image class="hero-logo" src="{{logoUrl}}" mode="aspectFill" />
      <view class="hero-copy">
        <text class="hero-title">个人信息</text>
        <text class="hero-meta">{{statusText}}</text>
      </view>
    </view>
  </view>

  <view class="section card profile-card">
    <view class="profile-avatar-block">
      <!-- WXML -->
      <view class="avatar-wrapper">
        <button class="profile-avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{avatarDisplayUrl}}" class="profile-avatar" src="{{avatarDisplayUrl}}" mode="aspectFill" />
          <view wx:else class="profile-avatar-placeholder">
            <view class="avatar-icon">
              <view class="avatar-icon-head"></view>
              <view class="avatar-icon-body"></view>
            </view>
          </view>
        </button>
      </view>
      <text class="profile-avatar-hint">点击使用微信头像</text>
    </view>

    <view class="field profile-name-field">
      <text class="field-label">昵称</text>
      <input
        class="text-input"
        type="nickname"
        maxlength="20"
        placeholder="点击使用微信昵称"
        value="{{profile.nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameInput"
      />
    </view>

    <button class="primary-button profile-save-button" hover-class="button-hover" loading="{{saving}}" disabled="{{loading}}" bindtap="saveProfile">保存资料</button>
  </view>
</view>
