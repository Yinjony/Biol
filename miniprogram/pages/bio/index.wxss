.app-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f4f7f5;
}

.app-header {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #10251d;
  color: #f7fbf8;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 16rpx;
  background: #dff3e8;
  color: #10251d;
  font-size: 30rpx;
  font-weight: 800;
}

.brand-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 4rpx;
}

.brand-title {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.brand-subtitle {
  color: rgba(247, 251, 248, 0.68);
  font-size: 24rpx;
}

.nav-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.nav-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(247, 251, 248, 0.78);
  font-size: 28rpx;
}

.nav-tab.active,
.nav-tab-hover {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.summary-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-item {
  min-height: 112rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.08);
}

.summary-value {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.summary-label {
  color: rgba(247, 251, 248, 0.7);
  font-size: 22rpx;
}

.workspace {
  padding-top: 24rpx;
}

.view-panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.toolbar-title {
  display: block;
  color: #1f2a24;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.toolbar-meta {
  display: block;
  margin-top: 6rpx;
  color: #68746d;
  font-size: 24rpx;
}

.search-row,
.editor-panel,
.question-card,
.quiz-card,
.parse-panel,
.empty-state {
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(31, 42, 36, 0.06);
}

.search-row {
  padding: 18rpx;
}

.editor-panel,
.question-card,
.quiz-card,
.parse-panel {
  padding: 24rpx;
}

.field-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 208rpx;
  gap: 18rpx;
}

.field {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
}

.field + .field,
.option-fields,
.form-actions,
.parse-panel {
  margin-top: 18rpx;
}

.field-label {
  color: #68746d;
  font-size: 24rpx;
}

.text-input,
.picker-input,
.textarea {
  width: 100%;
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
}

.text-input,
.picker-input {
  min-height: 78rpx;
  padding: 0 22rpx;
  line-height: 78rpx;
}

.textarea {
  min-height: 180rpx;
  padding: 20rpx 22rpx;
  line-height: 1.55;
}

.import-textarea {
  min-height: 420rpx;
}

.option-fields {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-actions,
.card-actions,
.import-actions,
.quiz-control-row {
  display: flex;
  gap: 14rpx;
}

.form-actions {
  justify-content: flex-end;
}

.primary-button,
.secondary-button,
.tiny-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  padding: 0 26rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  white-space: nowrap;
}

.primary-button {
  background: #1f8a5b;
  color: #ffffff;
}

.secondary-button,
.tiny-button {
  border: 1rpx solid #dce5df;
  background: #ffffff;
  color: #1f2a24;
}

.compact-button {
  min-width: 150rpx;
}

.button-hover {
  opacity: 0.82;
}

.question-list,
.quiz-board {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.card-header,
.quiz-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.question-title {
  flex: 1;
  min-width: 0;
  color: #1f2a24;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-word;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  background: #e1eef7;
  color: #245679;
  font-size: 22rpx;
  line-height: 44rpx;
  white-space: nowrap;
}

.answer-tag {
  background: #dff3e8;
  color: #14663f;
}

.card-options {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
  color: #68746d;
  font-size: 26rpx;
  line-height: 1.55;
}

.option-line {
  white-space: pre-wrap;
  word-break: break-word;
}

.card-actions {
  justify-content: flex-end;
  margin-top: 20rpx;
}

.tiny-button {
  min-height: 62rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.danger-text {
  color: #bf4b32;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 280rpx;
  padding: 36rpx;
  color: #68746d;
  font-size: 28rpx;
  text-align: center;
}

.quiz-control-row {
  flex-wrap: wrap;
}

.quiz-control-row .primary-button,
.quiz-control-row .secondary-button {
  flex: 1 1 180rpx;
}

.count-picker {
  flex: 1 1 220rpx;
}

.quiz-title-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  min-width: 0;
}

.quiz-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  background: #eef5ef;
  color: #14663f;
  font-size: 26rpx;
  font-weight: 800;
}

.answer-buttons {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.answer-option {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-height: 82rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #dce5df;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2a24;
  font-size: 28rpx;
  line-height: 1.45;
  text-align: left;
  white-space: normal;
  word-break: break-word;
}

.answer-hover {
  border-color: #1f8a5b;
  background: #dff3e8;
}

.answer-option.correct {
  border-color: #167347;
  background: #dff6ea;
  color: #167347;
}

.answer-option.wrong {
  border-color: #bf4b32;
  background: #fde8e1;
  color: #bf4b32;
}

.answer-option[disabled] {
  opacity: 1;
}

.feedback {
  margin-top: 18rpx;
  color: #68746d;
  font-size: 26rpx;
}

.feedback.correct {
  color: #167347;
}

.feedback.wrong {
  color: #bf4b32;
}

.import-actions {
  flex-wrap: wrap;
}

.import-actions button {
  flex: 1 1 200rpx;
}

.parse-title {
  display: block;
  color: #1f2a24;
  font-size: 32rpx;
  font-weight: 800;
}

.parse-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.parse-label {
  color: #68746d;
  font-size: 24rpx;
}

.parse-value {
  color: #1f2a24;
  font-size: 28rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-word;
}

@media (min-width: 720px) {
  .app-shell {
    max-width: 720px;
    margin: 0 auto;
  }

  .answer-buttons {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
