<view class="app-shell">
  <view class="app-header">
    <view class="brand-row">
      <view class="brand-mark">Bio</view>
      <view class="brand-copy">
        <text class="brand-title">生物做题</text>
        <text class="brand-subtitle">V0.1 本地题库</text>
      </view>
    </view>

    <view class="nav-tabs">
      <button
        wx:for="{{navItems}}"
        wx:key="key"
        class="nav-tab {{item.active ? 'active' : ''}}"
        hover-class="nav-tab-hover"
        data-view="{{item.key}}"
        bindtap="onNavTap"
      >
        {{item.text}}
      </button>
    </view>

    <view class="summary-strip">
      <view class="summary-item">
        <text class="summary-value">{{stats.total}}</text>
        <text class="summary-label">题目</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{stats.choice}}</text>
        <text class="summary-label">选择</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{stats.judge}}</text>
        <text class="summary-label">判断</text>
      </view>
    </view>
  </view>

  <view class="workspace">
    <view wx:if="{{showBank}}" class="view-panel">
      <view class="toolbar">
        <view>
          <text class="toolbar-title">题库管理</text>
          <text class="toolbar-meta">{{resultCountText}}</text>
        </view>
        <button class="primary-button compact-button" hover-class="button-hover" bindtap="newQuestion">新增题目</button>
      </view>

      <view class="search-row">
        <input
          class="text-input"
          type="text"
          confirm-type="search"
          placeholder="输入题干关键词"
          value="{{searchQuery}}"
          bindinput="onSearchInput"
        />
      </view>

      <view class="editor-panel">
        <view class="field-row">
          <view class="field">
            <text class="field-label">题型</text>
            <picker mode="selector" range="{{questionTypeNames}}" value="{{questionTypeIndex}}" bindchange="onQuestionTypeChange">
              <view class="picker-input">{{questionTypeName}}</view>
            </picker>
          </view>
          <view class="field answer-field">
            <text class="field-label">答案</text>
            <input
              class="text-input"
              type="text"
              maxlength="10"
              placeholder="{{answerPlaceholder}}"
              value="{{answerInput}}"
              bindinput="onAnswerInput"
            />
          </view>
        </view>

        <view class="field">
          <text class="field-label">题干</text>
          <textarea
            class="textarea"
            maxlength="-1"
            placeholder="请输入题干"
            value="{{contentInput}}"
            bindinput="onContentInput"
          />
        </view>

        <view wx:if="{{isChoiceType}}" class="option-fields">
          <view class="field" wx:for="{{optionFields}}" wx:for-item="option" wx:key="label">
            <text class="field-label">{{option.label}}</text>
            <input
              class="text-input"
              type="text"
              placeholder="选项 {{option.label}}"
              value="{{option.value}}"
              data-label="{{option.label}}"
              bindinput="onOptionInput"
            />
          </view>
        </view>

        <view class="form-actions">
          <button class="secondary-button" hover-class="button-hover" bindtap="resetForm">清空</button>
          <button class="primary-button" hover-class="button-hover" bindtap="saveQuestion">保存题目</button>
        </view>
      </view>

      <view class="question-list" wx:if="{{hasDisplayQuestions}}">
        <view class="question-card" wx:for="{{displayQuestions}}" wx:for-item="question" wx:key="id">
          <view class="card-header">
            <text class="question-title">{{question.content}}</text>
            <text class="tag type-tag">{{question.typeName}}</text>
          </view>
          <view class="tag-row">
            <text class="tag answer-tag">答案：{{question.answer}}</text>
            <text class="tag">更新：{{question.updatedText}}</text>
          </view>
          <view class="card-options" wx:if="{{question.isChoice}}">
            <view wx:for="{{question.options}}" wx:for-item="option" wx:key="label" class="option-line">
              {{option.label}}. {{option.text}}
            </view>
          </view>
          <view class="card-actions">
            <button class="tiny-button" hover-class="button-hover" data-id="{{question.id}}" bindtap="editQuestion">修改</button>
            <button class="tiny-button danger-text" hover-class="button-hover" data-id="{{question.id}}" bindtap="confirmDeleteQuestion">删除</button>
          </view>
        </view>
      </view>
      <view class="empty-state" wx:else>没有匹配的题目</view>
    </view>

    <view wx:if="{{showQuiz}}" class="view-panel">
      <view class="toolbar">
        <view>
          <text class="toolbar-title">开始做题</text>
          <text class="toolbar-meta">{{quizStatus}}</text>
        </view>
      </view>

      <view class="quiz-control-row">
        <picker class="count-picker" mode="selector" range="{{quizCountOptions}}" value="{{quizCountIndex}}" bindchange="onQuizCountChange">
          <view class="picker-input">抽题数：{{quizCount}}</view>
        </picker>
        <button class="primary-button" hover-class="button-hover" bindtap="startQuiz">随机开始</button>
        <button class="secondary-button" hover-class="button-hover" bindtap="submitQuiz">提交</button>
      </view>

      <view class="empty-state quiz-empty" wx:if="{{!hasQuizItems}}">点击随机开始</view>
      <view class="quiz-board" wx:else>
        <view class="quiz-card" wx:for="{{quizItems}}" wx:for-item="question" wx:key="id">
          <view class="quiz-header">
            <view class="quiz-title-row">
              <text class="quiz-index">{{question.displayIndex}}</text>
              <text class="question-title">{{question.content}}</text>
            </view>
            <text class="tag type-tag">{{question.typeName}}</text>
          </view>

          <view class="answer-buttons">
            <button
              wx:for="{{question.answerOptions}}"
              wx:for-item="option"
              wx:key="label"
              class="answer-option {{option.className}}"
              disabled="{{question.answered}}"
              hover-class="answer-hover"
              data-id="{{question.id}}"
              data-answer="{{option.label}}"
              bindtap="answerQuestion"
            >
              {{option.displayText}}
            </button>
          </view>

          <view class="feedback {{question.feedbackClass}}" wx:if="{{question.answered}}">
            {{question.feedbackText}}
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{showImport}}" class="view-panel">
      <view class="toolbar">
        <view>
          <text class="toolbar-title">上传题目</text>
          <text class="toolbar-meta">OCR / 文档文本</text>
        </view>
      </view>

      <view class="import-actions">
        <button class="secondary-button" hover-class="button-hover" bindtap="chooseImportFile">读取文本文件</button>
        <button class="secondary-button" hover-class="button-hover" bindtap="pasteClipboard">粘贴剪贴板</button>
        <button class="primary-button" hover-class="button-hover" bindtap="parseImportText">智能填入</button>
      </view>

      <view class="field">
        <text class="field-label">识别内容</text>
        <textarea
          class="textarea import-textarea"
          maxlength="-1"
          placeholder="粘贴 OCR 或 Word 提取出的文本"
          value="{{rawImportText}}"
          bindinput="onRawImportInput"
        />
      </view>

      <view class="parse-panel">
        <text class="parse-title">识别结果</text>
        <view class="parse-row">
          <text class="parse-label">题型</text>
          <text class="parse-value">{{parsed.typeName}}</text>
        </view>
        <view class="parse-row">
          <text class="parse-label">题干</text>
          <text class="parse-value">{{parsed.content}}</text>
        </view>
        <view class="parse-row">
          <text class="parse-label">选项</text>
          <text class="parse-value">{{parsed.optionsText}}</text>
        </view>
      </view>
    </view>
  </view>
  
</view>
